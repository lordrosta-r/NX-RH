{
  "name": "nanoxplore-rh-server-mongo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "seed": "node ../database/seed.js",
    "seed:users": "node -e \"process.env.NODE_PATH = require('path').resolve('./node_modules'); require('module').Module._initPaths(); require('../database/seed-users.js');\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "clearMocks": true,
    "restoreMocks": true
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "mongoose": "^8.4.0",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
