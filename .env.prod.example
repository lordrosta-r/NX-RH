# =============================================================================
# NanoXplore RH — Template de configuration PRODUCTION
#
# Copier en `.env` sur le serveur de prod et REMPLACER toutes les valeurs
# < ... >. NE JAMAIS committer le .env réel.
#
# Le serveur REFUSE de démarrer en production (NODE_ENV=production) si :
#   • JWT_SECRET ressemble à une valeur dev/par défaut (dev_, changeme, ...)
#   • E2E_MODE=true (désactive le rate-limit de login)
#   • MONGO_URI utilise le mot de passe « changeme »
# (voir mongo/server/index.js → start())
# =============================================================================

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Secrets (OBLIGATOIRE de régénérer) ──────────────────────────────────────
# Générer : openssl rand -hex 48   (≥ 64 caractères aléatoires)
JWT_SECRET=<openssl rand -hex 48>
JWT_REFRESH_SECRET=<openssl rand -hex 48>
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Base de données ─────────────────────────────────────────────────────────
MONGO_ROOT_USER=nxrh_app
MONGO_ROOT_PASSWORD=<mot de passe fort généré>
MONGO_DB=nanoxplore_rh
MONGO_URI=mongodb://nxrh_app:<mot de passe fort>@mongo:27017/nanoxplore_rh?authSource=admin

# ── Cookies / CORS (HTTPS obligatoire en prod) ──────────────────────────────
COOKIE_SECURE=true
CLIENT_ORIGIN=https://rh.votre-domaine.fr
FRONTEND_URL=https://rh.votre-domaine.fr

# ── E2E : DOIT rester vide/false en production ──────────────────────────────
# E2E_MODE=

# ── LDAP (optionnel — sinon laisser vide, auth locale uniquement) ───────────
# La config multi-annuaires se gère aussi via l'UI admin (/admin/integrations).
LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(uid={{u}})
LDAP_TLS_REJECT_UNAUTHORIZED=true

# ── SMTP (notifications email) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NanoXplore RH <rh@votre-domaine.fr>

UPLOADS_DIR=/data/uploads
