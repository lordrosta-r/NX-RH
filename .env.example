# =============================================================================
# NanoXplore RH — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug              # debug | info | warn | error
SCHEDULER_DISABLED=false     # true → disable cron jobs (CI / test environments)
UPLOADS_DIR=./uploads        # directory for uploaded files (relative or absolute)

# ─── Database (MongoDB) ───────────────────────────────────────────────────────
MONGO_URI=mongodb://CHANGE_ME_USER:CHANGE_ME_PASSWORD@mongo:27017/nanoxplore_rh?authSource=admin
MONGO_ROOT_USER=CHANGE_ME_USER
MONGO_ROOT_PASSWORD=CHANGE_ME_PASSWORD
MONGO_DB=nanoxplore_rh

# ─── Authentication ───────────────────────────────────────────────────────────
# AUTH_PROVIDER controls how users authenticate:
#   local  → username/password verified against the local `users` table
#   ldap   → credentials verified against LDAP/Active Directory
AUTH_PROVIDER=local

JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12             # bcrypt work factor — lower in tests (e.g. 1) to speed them up

# ─── Session & Cookies ────────────────────────────────────────────────────────
COOKIE_SECURE=false          # true in production (requires HTTPS)

# ─── LDAP (only required when AUTH_PROVIDER=ldap) ────────────────────────────
# LDAP_TYPE selects the directory flavour:
#   activedirectory  → Windows Active Directory (matches sAMAccountName / UPN)
#   openldap         → Linux OpenLDAP (matches uid / cn)
LDAP_TYPE=activedirectory

# LDAP server URL — use ldaps:// for TLS (recommended), ldap:// for plain
LDAP_URL=ldaps://dc.corp.local:636

# Base DN — root of your directory tree
LDAP_BASE_DN=DC=corp,DC=local

# Service account used to search the directory (needs read access)
LDAP_BIND_DN=CN=svc-nanoxplore,OU=Service Accounts,DC=corp,DC=local
LDAP_BIND_PASSWORD=service_account_password

# Where to search for user objects
LDAP_USER_SEARCH_BASE=OU=Users,DC=corp,DC=local

# Filter to locate a user by login. Use {{u}} as placeholder for the username/email.
#   Active Directory : (sAMAccountName={{u}})
#   OpenLDAP         : (uid={{u}})
# This variable is required when AUTH_PROVIDER=ldap
LDAP_USER_FILTER=(sAMAccountName={{u}})

# Set to false only if your LDAP cert is self-signed (never in production)
LDAP_TLS_REJECT_UNAUTHORIZED=true

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
# Works with any SMTP relay: Exchange, Postfix, Gmail, Microsoft 365, Mailtrap…
MAIL_HOST=smtp.yourcompany.com
MAIL_PORT=587
# true  = SMTPS (port 465, implicit TLS)
# false = STARTTLS (port 587, explicit TLS — most common)
MAIL_SECURE=false
MAIL_USER=notifications@nanoxplore.com
MAIL_PASSWORD=smtp_password_here
MAIL_FROM="NanoXplore RH <notifications@nanoxplore.com>"

# Development: use Mailtrap to catch all outgoing emails locally
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USER=<mailtrap_user>
# MAIL_PASSWORD=<mailtrap_pass>

# ─── SMTP (Admin health-check & status endpoint) ─────────────────────────────
# Used by /api/admin/status to verify SMTP connectivity.
# Leave blank to skip the SMTP health check.
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_SECURE=false            # false = STARTTLS (port 587), true = SMTPS (port 465)
SMTP_USER=notifications@nanoxplore.com
SMTP_PASS=smtp_password_here
SMTP_FROM="NanoXplore RH <notifications@nanoxplore.com>"

# ─── MinIO Storage (optional — falls back to local disk if absent) ────────────
# Set all three MINIO_* vars to enable MinIO/S3-compatible object storage.
# If not set, uploaded files are stored on local disk (UPLOADS_DIR).
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=nxrh

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origines autorisées (séparées par virgule). Jamais * en production.
CLIENT_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173   # URL used in email links (user import, password reset…)
