# =============================================================================
# NanoXplore RH — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=nanoxplore
DB_PASSWORD=your_strong_password_here
DB_NAME=nanoxplore_rh

# ─── Authentication ───────────────────────────────────────────────────────────
# AUTH_PROVIDER controls how users authenticate:
#   local  → username/password verified against the local `users` table
#   ldap   → credentials verified against LDAP/Active Directory
AUTH_PROVIDER=local

JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=8h

# ─── LDAP (only required when AUTH_PROVIDER=ldap) ────────────────────────────
# LDAP_TYPE selects the directory flavour:
#   activedirectory  → Windows Active Directory (matches sAMAccountName / UPN)
#   openldap         → Linux OpenLDAP (matches uid / cn)
LDAP_TYPE=activedirectory

# LDAP server URL — use ldaps:// for TLS (recommended), ldap:// for plain
LDAP_URL=ldaps://dc.corp.local:636

# Base DN — root of your directory tree
LDAP_BASE_DN=DC=corp,DC=local

# Service account used to search the directory (needs read access)
LDAP_BIND_DN=CN=svc-nanoxplore,OU=Service Accounts,DC=corp,DC=local
LDAP_BIND_PASSWORD=service_account_password

# Where to search for user objects
LDAP_USER_SEARCH_BASE=OU=Users,DC=corp,DC=local

# Set to false only if your LDAP cert is self-signed (never in production)
LDAP_TLS_REJECT_UNAUTHORIZED=true

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
# Works with any SMTP relay: Exchange, Postfix, Gmail, Microsoft 365, Mailtrap…
MAIL_HOST=smtp.yourcompany.com
MAIL_PORT=587
# true  = SMTPS (port 465, implicit TLS)
# false = STARTTLS (port 587, explicit TLS — most common)
MAIL_SECURE=false
MAIL_USER=notifications@nanoxplore.com
MAIL_PASSWORD=smtp_password_here
MAIL_FROM="NanoXplore RH <notifications@nanoxplore.com>"

# Development: use Mailtrap to catch all outgoing emails locally
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USER=<mailtrap_user>
# MAIL_PASSWORD=<mailtrap_pass>
