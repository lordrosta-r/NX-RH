# =============================================================================
# NanoXplore RH — Variables d'environnement (mongo/server)
# Copier en .env et remplir les valeurs réelles. Ne JAMAIS committer .env.
# =============================================================================

# ─── Serveur ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug              # debug | info | warn | error
SCHEDULER_DISABLED=false     # true → désactive les cron jobs (CI / tests)
UPLOADS_DIR=./uploads        # répertoire des fichiers uploadés (relatif ou absolu)

# ─── Base de données (MongoDB) ────────────────────────────────────────────────
MONGO_URI=mongodb://CHANGE_ME_USER:CHANGE_ME_PASSWORD@mongo:27017/nanoxplore_rh?authSource=admin
MONGO_ROOT_USER=CHANGE_ME_USER
MONGO_ROOT_PASSWORD=CHANGE_ME_PASSWORD
MONGO_DB=nanoxplore_rh

# ─── Authentification ─────────────────────────────────────────────────────────
# AUTH_PROVIDER : mode d'authentification des utilisateurs
#   local  → mot de passe vérifié contre la table users locale
#   ldap   → identifiants vérifiés contre LDAP / Active Directory
AUTH_PROVIDER=local

# JWT_SECRET : clé secrète de signature des tokens d'accès.
# Générer avec : node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=CHANGE_ME_64_CHARS_RANDOM_HEX

# JWT_REFRESH_SECRET : clé distincte pour les refresh tokens (rotation).
# Ne pas réutiliser JWT_SECRET — deux clés séparées limitent la surface d'attaque.
JWT_REFRESH_SECRET=CHANGE_ME_64_CHARS_RANDOM_HEX_DIFFERENT

JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12             # facteur de coût bcrypt — réduire à 1 en tests pour la vitesse

# ─── Session & Cookies ────────────────────────────────────────────────────────
COOKIE_SECURE=false          # true en production (nécessite HTTPS)

# ─── LDAP (requis uniquement si AUTH_PROVIDER=ldap) ──────────────────────────
# LDAP_TYPE : type d'annuaire
#   activedirectory  → Windows Active Directory (sAMAccountName / UPN)
#   openldap         → Linux OpenLDAP (uid / cn)
LDAP_TYPE=activedirectory

# URL du serveur LDAP — préférer ldaps:// (TLS) à ldap:// (texte clair)
LDAP_URL=ldaps://dc.corp.local:636

# Base DN — racine de l'arbre d'annuaire
LDAP_BASE_DN=DC=corp,DC=local

# Compte de service utilisé pour chercher dans l'annuaire (accès lecture)
LDAP_BIND_DN=CN=svc-nanoxplore,OU=Service Accounts,DC=corp,DC=local
LDAP_BIND_PASSWORD=CHANGE_ME_SERVICE_ACCOUNT_PASSWORD

# Branche de recherche des comptes utilisateurs
LDAP_USER_SEARCH_BASE=OU=Users,DC=corp,DC=local

# Filtre de localisation par login. {{u}} = placeholder pour le nom d'utilisateur/email.
#   Active Directory : (sAMAccountName={{u}})
#   OpenLDAP         : (uid={{u}})
LDAP_USER_FILTER=(sAMAccountName={{u}})

# false uniquement si le certificat LDAP est auto-signé (jamais en production)
LDAP_TLS_REJECT_UNAUTHORIZED=true

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
# Compatible avec tout relais SMTP : Exchange, Postfix, Gmail, Microsoft 365, Mailtrap…
MAIL_HOST=smtp.yourcompany.com
MAIL_PORT=587
# true  = SMTPS (port 465, TLS implicite)
# false = STARTTLS (port 587, TLS explicite — le plus courant)
MAIL_SECURE=false
MAIL_USER=notifications@nanoxplore.com
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM="NanoXplore RH <notifications@nanoxplore.com>"

# Développement : utiliser Mailtrap pour intercepter les emails localement
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USER=CHANGE_ME_MAILTRAP_USER
# MAIL_PASSWORD=CHANGE_ME_MAILTRAP_PASSWORD

# ─── SMTP (health-check & status admin) ──────────────────────────────────────
# Utilisé par /api/admin/status pour vérifier la connectivité SMTP.
# Laisser vide pour ignorer le check SMTP.
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@nanoxplore.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="NanoXplore RH <notifications@nanoxplore.com>"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origines autorisées (séparées par virgule). Jamais * en production.
CLIENT_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173   # URL dans les liens email (import, reset mot de passe…)
