# NanoXplore RH — Variables d'environnement

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# URI complète avec identifiants (créés dans database/mongo-init.js)
MONGO_URI=mongodb://nanoxplore:changeme@mongo:27017/nanoxplore_rh?authSource=nanoxplore_rh

# Pour Docker local (mongo-init crée l'admin root MongoDB)
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=rootsecret
MONGO_INITDB_DATABASE=nanoxplore_rh
# Mot de passe de l'utilisateur applicatif (utilisé dans mongo-init.js)
MONGO_APP_PASSWORD=changeme

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
# Durée de validité du token (ex: 8h, 1d, 7d)
JWT_EXPIRES_IN=8h

# ─── LDAP / LDAPS ─────────────────────────────────────────────────────────────
# URL de l'annuaire (ldaps:// en production, ldap:// en dev uniquement)
LDAP_URL=ldaps://dc.corp.com:636

# Base de recherche des utilisateurs
LDAP_BASE_DN=ou=people,dc=corp,dc=com

# Compte de service pour lire l'annuaire (lecture seule)
LDAP_BIND_DN=cn=svc-nanoxplore,dc=corp,dc=com
LDAP_BIND_PASSWORD=service_account_password

# Filtre de recherche — remplacer {{u}} par le login entré par l'utilisateur
# Active Directory : (sAMAccountName={{u}})
# OpenLDAP Linux   : (uid={{u}})
LDAP_USER_FILTER=(sAMAccountName={{u}})

# Vérification TLS (toujours true en production)
LDAP_TLS_REJECT_UNAUTHORIZED=true

# ─── Email (nodemailer) ───────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=rh@example.com
MAIL_PASSWORD=smtp_password
MAIL_FROM="NanoXplore RH <rh@example.com>"

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Répertoire de stockage des fichiers uploadés (ressources RH)
UPLOADS_DIR=/app/uploads
